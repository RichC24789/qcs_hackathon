    var response = await fetch(`${this.apiUrl}/assets/policy/${id}`, {
      method: 'GET',
      headers: this.getHeaders()
    });
    if (response.ok) {
      return response;
    }
  }
  async getById(id, itemType, locale) {
    var response = await fetch(`${this.apiUrl}/items/${itemType}/${id}/${id}?locale=${locale}`, {
      method: 'GET',
      headers: this.getHeaders()
    });
    if (response.ok) {
      return response.json();
    }
    return {
      status: response.status,
      statusText: response.statusText
    };
  }
  getHeaders() {
    const headers = new Headers({
      'Content-Type': 'application/json'
    });
    if (this.token) {
      headers.set('Authorization', `Bearer ${this.token}`);
    }
    if (!this.options) return headers;
    if (this.options.filterSections) headers.set('X-Sections', this.options.filterSections.toString());
