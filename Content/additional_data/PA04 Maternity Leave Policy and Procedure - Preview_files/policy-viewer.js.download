class DlwDialogUtils extends DlwBaseWebComponent {
  //** Turn off ShadowDOM */
  createRenderRoot() {
    return this;
  }
  init() {
    const dlwDialog = this.querySelector("dialog");
    const openAttribute = this.getAttribute("open-on-start");
    const idDialog = this.getAttribute("name");
    const closeElementAttribute = this.querySelectorAll("[data-dialog-close]");
    const firstHElement = this.querySelectorAll("h1, h2, h3, h4, h5, h6")[0];
    const closeOutsideAttribute = super.getAttributeValue("close-on-click-outside");
    this.disableBodyScroll = super.getAttributeValue("disable-body-scroll");
    if (dlwDialog !== undefined) {
      dlwDialog.removeAttribute("open");
      if (closeOutsideAttribute) {
        document.addEventListener("click", e => {
          if (!this.contains(e.target) && dlwDialog.getAttribute("open") != null && e.target.getAttribute("data-dialog-id") == null) {
            dlwDialog.close();
          }
        });
      }
      // Re-enable body scroll when dialog closes.
      if (this.disableBodyScroll) {
        dlwDialog.addEventListener("close", () => {
          toggleBodyScroll(false);
        });
      }
      Array.from(closeElementAttribute).forEach(element => {
        element.addEventListener("click", () => {
          if (element.getAttribute("data-dialog-close") === "true") {
            dlwDialog.close();
          }
        });
      });
      Array.from(document.querySelectorAll(`#${idDialog}`)).forEach(element => {
        element.addEventListener("click", () => {
          this.openDialog(dlwDialog);
        });
      });
      document.addEventListener("click", e => {
        if (e.target.closest("[data-dialog-id]")?.attributes["data-dialog-id"].value === dlwDialog.id) this.openDialog(dlwDialog);
      });
      this.openOnStartFunction(dlwDialog, openAttribute);
      this.addAriaLabelledBy(firstHElement, dlwDialog);
    } else {
      console.log("please add a dialog inside the dlw-dialog brackets");
    }
  }
  // Open the dialog when the page is loaded if the attribute "open-on-start" is true
  openOnStartFunction(dlwDialog, openAttribute) {
    if (openAttribute === "true") {
      this.openDialog(dlwDialog);
    }
  }
  // Open the dialog
  openDialog(dlwDialog) {
    dlwDialog.showModal();
    this.checkForEscape(dlwDialog);
    if (this.disableBodyScroll) toggleBodyScroll(true);
  }
  // Close dialog on escape if the "close-on-esc" attribtue is true
  checkForEscape(element) {
    this.addEventListener("keydown", e => {
