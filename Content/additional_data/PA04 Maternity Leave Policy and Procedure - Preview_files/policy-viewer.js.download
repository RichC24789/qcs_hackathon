// Class for handling DOM Events sent by external sources. 
class QCS_Action_Handler {
  constructor(policyId, policy, odsClient, config) {
    this.policyId = policyId;
    this.policy = policy;
    this.odsClient = odsClient;
    QCS_Action_Handler.config = config;
    document.addEventListener(Qcs_Events.Qcs_Download_Pdf, async e => {
      await this.handleDownloadPDF();
    });
    document.addEventListener(Qcs_Events.Qcs_Print_Pdf, async e => {
      await this.handlePrintPDF();
    });
  }
  async handleDownloadPDF() {
    await this.retrievePDFUrl().then(url => {
      downloadFile(url, `${this.policy.referenceNumber} - ${this.policy.name}`);
    });
  }
  async handlePrintPDF() {
    await this.retrievePDFUrl().then(url => {
      let iframe = document.createElement("iframe");
      iframe.style.display = "none";
      iframe.src = url;
      iframe.onload = () => {
        iframe.focus();
        iframe.contentWindow.print();
      };
      document.body.appendChild(iframe);
    });
  }
  async retrievePDFUrl() {
    const pdfResponse = await this.odsClient.retrievePDF(this.policyId);
    const blob = await pdfResponse.blob();
    return window.URL.createObjectURL(blob);
  }
  static dispatch(event, detail) {
    // Add default properties.
    if (detail) detail.isTrial = this.config.configToken?.isTrialUser;
    document.dispatchEvent(new CustomEvent(event, {
      detail: detail
    }));
  }
}
;// CONCATENATED MODULE: ./src/apiclients/QCS_Apiclient.ts
class QCS_Apiclient {
  constructor(apiUrl, accessToken) {
    this.apiUrl = apiUrl;
    this.accessToken = accessToken;
  }
  getHeaders() {
    const headers = new Headers({
      'Content-Type': 'application/json'
    });
    if (this.accessToken) {
      headers.set('Authorization', `Bearer ${this.accessToken}`);
    }
    return headers;
  }
  async getResources(policyRef) {
    try {
      var response = await fetch(`${this.apiUrl}/get-resources-for-policy/${policyRef}`, {
        method: 'GET',
        headers: this.getHeaders()
      });
      if (response.ok) {
        return response.status === 204 ? [] : response.json();
      }
    } catch (error) {
      console.error(error);
    }
  }
  async openStatistics(policyRef, isMobile) {
    try {
      var response = await fetch(`${this.apiUrl}/open-view-stats/${policyRef}/${isMobile}`, {
        method: 'POST',
        headers: this.getHeaders()
      });
      if (response.ok) {
        let jsonResponse = await response.json();
        return jsonResponse.logId;
      }
    } catch (error) {
      console.error(error);
    }
  }
  async closeStatistics(policyRef, logId) {
    try {
      var response = await fetch(`${this.apiUrl}/close-view-stats/${policyRef}/${logId}`, {
        method: 'POST',
        headers: this.getHeaders()
      });
    } catch (error) {
      console.error(error);
    }
  }
  async getBlogContent(blogId) {
    try {
      var response = await fetch(`${this.apiUrl}/blog/${blogId}`, {
        method: 'POST',
        headers: this.getHeaders()
      });
      if (response.ok) {
        return await response.json();
      } else {
        console.error(response.status);
      }
    } catch (error) {
      console.error(error);
    }
  }
}
